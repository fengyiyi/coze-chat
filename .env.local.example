# ============================================================
# Coze 智能体访问令牌（务必保密，切勿提交到仓库）
# ⚠️ ESA 单条环境变量 Value 上限 200 字符，Coze Bearer 令牌约 739 字符，
#    必须按 200 字符一片分片存储（COZE_TOKEN_1..4），运行时自动拼接。
# 本地（无 200 字符限制）也可用单行完整令牌：COZE_TOKEN=完整令牌
# ============================================================
COZE_TOKEN_1=粘贴第1片令牌（≤200字符）
COZE_TOKEN_2=粘贴第2片令牌
COZE_TOKEN_3=粘贴第3片令牌
COZE_TOKEN_4=粘贴第4片令牌
# COZE_TOKEN=本地可用完整令牌（与上面分片二选一，分片优先）

# ============================================================
# 允许访问的域名白名单（多个用逗号分隔，大小写不敏感）
# 生产环境务必设为你的域名，例如：ai.alfedu.com
# 留空 = 本地开发时不限制域名（生产请务必填写！）
# ============================================================
ALLOWED_HOST=ai.alfedu.com

# ============================================================
# 本地调试端口（可选，server.mjs 使用）
# ============================================================
PORT=3000
